          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(http_errors_total[1m])) / clamp_min(sum by (path) (rate(http_requests_total[1m])), 0.0001)",
